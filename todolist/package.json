{
  "name": "todolist-widget",
  "version": "1.0.0",
  "private": true,
  "description": "A floating always-on-top To‑Do widget for Windows (Electron).",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "dist": "npm run build"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.cursor.todolist",
    "productName": "To-Do List Widget",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "script.js",
      "style.css"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false
    }
  }
}
